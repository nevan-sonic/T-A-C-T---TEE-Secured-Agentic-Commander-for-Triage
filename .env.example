# Terminal 3 Network Configuration
T3N_API_KEY=
T3N_ENVIRONMENT=testnet
T3N_TENANT_DID=

# Groq LLM Configuration
GROQ_API_KEY=

# Git / Workspace Configuration
WORKSPACE_DIR=
GIT_REAL_EXECUTION=true
GITHUB_REPO=
GITHUB_TOKEN=

# Slack Webhook URL (leave empty for mock console notifications)
SLACK_WEBHOOK_URL=

# Engineer DIDs are dynamically resolved on startup from authenticated sessions.
# Configured keys below will handshake/authenticate to retrieve opaque DIDs.
ALICE_PRIVATE_KEY=
BOB_PRIVATE_KEY=
CHARLIE_PRIVATE_KEY=

# Disable auto-simulation mode (set to 'true' to require manual trigger)
DISABLE_AUTO_SIMULATION=false
