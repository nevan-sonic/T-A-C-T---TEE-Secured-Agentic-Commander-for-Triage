# Terminal 3 Network Configuration
T3N_API_KEY=your_t3n_private_key
T3N_TENANT_DID=did:t3n:your_t3n_tenant_did
T3_AGENT_DID=did:t3:agent:department-of-incidents
T3_PRIVATE_KEY=your_t3_private_key
T3_LEDGER_URL=https://ledger.terminal3.io

# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key

# Git Simulation Configuration
# Set to 'true' to execute real git commands on the filesystem, 'false' to mock them
GIT_REAL_EXECUTION=true
# Optional GitHub configuration (falls back to local Git repository if blank)
GITHUB_REPO=nevan-sonic/T.A.C.T.-TEE-Secured-Agentic-Commander-for-Triage-
GITHUB_TOKEN=your_github_personal_access_token

# Slack Webhook URL (leave empty for mock console notifications)
SLACK_WEBHOOK_URL=your_slack_webhook_url

# Engineer DIDs are dynamically resolved on startup fromauthenticated sessions.
# Configured keys below will handshake/authenticate to retrieve opaque DIDs.
ALICE_PRIVATE_KEY=your_alice_wallet_private_key
BOB_PRIVATE_KEY=your_bob_wallet_private_key
CHARLIE_PRIVATE_KEY=your_charlie_wallet_private_key

